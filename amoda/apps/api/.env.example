# --- App ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://amoda:amoda@localhost:5432/amoda?schema=public

# --- Redis (caching, rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- JWT / Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# --- Apple Sign In ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Facebook Login ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AMODA <no-reply@amoda.app>"

# --- Cloudinary (media storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# --- Somali mobile money (WaafiPay aggregator) ---
WAAFIPAY_API_BASE_URL=https://api.waafipay.net/asm
HORMUUD_EVC_MERCHANT_UID=
HORMUUD_EVC_API_USER_ID=
HORMUUD_EVC_API_KEY=
ZAAD_MERCHANT_UID=
ZAAD_API_USER_ID=
ZAAD_API_KEY=
SAHAL_MERCHANT_UID=
SAHAL_API_USER_ID=
SAHAL_API_KEY=
PREMIER_WALLET_MERCHANT_UID=
PREMIER_WALLET_API_USER_ID=
PREMIER_WALLET_API_KEY=

# --- SMS ---
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# --- WhatsApp Business Cloud API ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100
