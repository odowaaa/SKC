// AMODA — Your Property Partner
// Prisma schema: normalized PostgreSQL data model for the real estate platform.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  REGIONAL_MANAGER
  BRANCH_MANAGER
  PROPERTY_MANAGER
  AGENT
  DEVELOPER
  OWNER
  TENANT
  CUSTOMER
  SUPPORT_STAFF
  ACCOUNTANT
  MARKETING_MANAGER
  MODERATOR
  GUEST
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  FACEBOOK
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  TOWNHOUSE
  DUPLEX
  STUDIO
  PENTHOUSE
  LAND
  FARM
  WAREHOUSE
  OFFICE
  RETAIL
  HOTEL
  HOSTEL
  INDUSTRIAL
  MIXED_USE
  RESTAURANT
  SHOP
  HOSPITAL
  SCHOOL
  BUILDING
  RESORT
  VACATION_HOME
}

enum ListingType {
  SALE
  RENT
  COMMERCIAL
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNDER_OFFER
  SOLD
  RENTED
  ARCHIVED
  REJECTED
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FURNISHED
}

enum OwnershipStatus {
  FREEHOLD
  LEASEHOLD
  COMMUNAL
  DISPUTED
}

enum MediaKind {
  IMAGE
  VIDEO
  VIRTUAL_TOUR
  FLOOR_PLAN
  DOCUMENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  PHONE
  WALK_IN
  ADVERTISEMENT
  OTHER
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  COUNTERED
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING_RENEWAL
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PaymentGatewayProvider {
  STRIPE
  PAYPAL
  HORMUUD_EVC
  ZAAD
  SAHAL
  PREMIER_WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Identity & Access
// ---------------------------------------------------------------------------

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  phone             String?      @unique
  passwordHash      String?
  firstName         String
  lastName          String
  avatarUrl         String?
  role              Role         @default(CUSTOMER)
  provider          AuthProvider @default(EMAIL)
  providerId        String?
  isEmailVerified   Boolean      @default(false)
  isPhoneVerified   Boolean      @default(false)
  isTwoFactorOn     Boolean      @default(false)
  twoFactorSecret   String?
  isActive          Boolean      @default(true)
  isSuspended       Boolean      @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  locale            String       @default("en")
  currency          String       @default("USD")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  permissions       UserPermission[]
  refreshTokens     RefreshToken[]
  otpCodes          OtpCode[]
  passwordResets    PasswordResetToken[]
  devices           UserDevice[]
  loginEvents       LoginEvent[]

  agentProfile      Agent?
  ownerProfile      Owner?
  tenantProfile     Tenant?
  developerProfile  Developer?

  propertiesCreated Property[]        @relation("PropertyCreatedBy")
  bookings          Booking[]         @relation("BookingCustomer")
  favorites         Favorite[]
  reviews           Review[]
  savedSearches     SavedSearch[]
  notifications     Notification[]
  supportTickets    SupportTicket[]   @relation("TicketRequester")
  assignedTickets   SupportTicket[]   @relation("TicketAssignee")
  ticketReplies     SupportTicketReply[]
  sentMessages      Message[]         @relation("MessageSender")
  conversations     ConversationParticipant[]
  invoices          Invoice[]
  payments          Payment[]
  subscriptions     Subscription[]
  leadsOwned        Lead[]            @relation("LeadAssignee")
  leadsCreated      Lead[]            @relation("LeadCreatedBy")
  auditLogs         AuditLog[]
  blogPosts         BlogPost[]
  uploadedFiles     File[]
  compareItems      CompareItem[]
  crmNotes          CrmNote[]
  crmTasks          CrmTask[]         @relation("CrmTaskAssignee")

  @@index([role])
  @@map("users")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  users UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  purpose   String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("otp_codes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  deviceName  String?
  pushToken   String?
  platform    String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("user_devices")
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_events")
}

// ---------------------------------------------------------------------------
// Role profiles
// ---------------------------------------------------------------------------

model Agent {
  id             String   @id @default(cuid())
  userId         String   @unique
  agencyName     String?
  licenseNumber  String?
  bio            String?
  yearsExperience Int?
  specialties    String[] @default([])
  serviceAreas   String[] @default([])
  commissionRate Decimal  @default(0) @db.Decimal(5, 2)
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[]  @relation("AgentProperties")
  bookings   Booking[]   @relation("AgentBookings")
  leads      Lead[]      @relation("AgentLeads")
  offers     Offer[]     @relation("AgentOffers")
  commissions Commission[]

  @@map("agents")
}

model Owner {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String?
  taxId         String?
  bankAccount   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[] @relation("OwnerProperties")
  leases     Lease[]    @relation("OwnerLeases")

  @@map("owners")
}

model Tenant {
  id             String   @id @default(cuid())
  userId         String   @unique
  emergencyName  String?
  emergencyPhone String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases Lease[] @relation("TenantLeases")
  maintenanceRequests MaintenanceRequest[]

  @@map("tenants")
}

model Developer {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  website     String?
  logoUrl     String?
  description String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("developers")
}

model Project {
  id           String   @id @default(cuid())
  developerId  String
  name         String
  slug         String   @unique
  description  String?
  city         String?
  country      String?
  startDate    DateTime?
  completionDate DateTime?
  status       String   @default("PLANNING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  developer  Developer  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  properties Property[]

  @@map("projects")
}

// ---------------------------------------------------------------------------
// Properties
// ---------------------------------------------------------------------------

model Property {
  id               String          @id @default(cuid())
  referenceCode    String          @unique
  slug             String          @unique
  title            String
  description      String
  type             PropertyType
  listingType      ListingType
  status           PropertyStatus  @default(DRAFT)

  price            Decimal         @db.Decimal(14, 2)
  currency         String          @default("USD")
  priceNegotiable  Boolean         @default(false)

  bedrooms         Int?
  bathrooms        Int?
  areaSqm          Decimal?        @db.Decimal(10, 2)
  lotSizeSqm       Decimal?        @db.Decimal(10, 2)
  floors           Int?
  floorNumber      Int?
  parkingSpaces    Int?            @default(0)
  yearBuilt        Int?
  energyRating     String?
  furnishing       FurnishingStatus?
  ownershipStatus  OwnershipStatus?

  hasSwimmingPool  Boolean         @default(false)
  hasGarden        Boolean         @default(false)
  petsAllowed      Boolean         @default(false)
  hasAirConditioning Boolean       @default(false)
  hasGym           Boolean         @default(false)
  hasSecurity      Boolean         @default(false)
  hasWater         Boolean         @default(true)
  hasElectricity   Boolean         @default(true)

  country          String
  city             String
  district         String?
  neighborhood     String?
  addressLine      String?
  postalCode       String?
  latitude         Decimal?        @db.Decimal(10, 7)
  longitude        Decimal?        @db.Decimal(10, 7)

  viewsCount       Int             @default(0)
  isFeatured       Boolean         @default(false)
  isLuxury         Boolean         @default(false)
  publishedAt      DateTime?
  availableFrom    DateTime?

  createdById      String
  agentId          String?
  ownerId          String?
  projectId        String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  createdBy  User        @relation("PropertyCreatedBy", fields: [createdById], references: [id])
  agent      Agent?      @relation("AgentProperties", fields: [agentId], references: [id])
  owner      Owner?      @relation("OwnerProperties", fields: [ownerId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])

  media          PropertyMedia[]
  amenities      PropertyAmenity[]
  categories     PropertyCategory[]
  nearbyPlaces   NearbyPlace[]
  bookings       Booking[]
  favorites      Favorite[]
  reviews        Review[]
  leads          Lead[]
  offers         Offer[]
  leases         Lease[]
  compareItems   CompareItem[]
  seo            SeoMeta?

  @@index([city, country])
  @@index([type, listingType, status])
  @@index([price])
  @@index([latitude, longitude])
  @@map("properties")
}

model PropertyMedia {
  id         String    @id @default(cuid())
  propertyId String
  kind       MediaKind
  url        String
  thumbnailUrl String?
  caption    String?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_media")
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  properties PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@map("property_amenities")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  parentId  String?
  createdAt DateTime @default(now())

  parent     Category?          @relation("CategoryChildren", fields: [parentId], references: [id])
  children   Category[]         @relation("CategoryChildren")
  properties PropertyCategory[]

  @@map("categories")
}

model PropertyCategory {
  id         String @id @default(cuid())
  propertyId String
  categoryId String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([propertyId, categoryId])
  @@map("property_categories")
}

model NearbyPlace {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  type       String
  distanceKm Decimal  @db.Decimal(6, 2)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("nearby_places")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model CompareItem {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("compare_items")
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@map("reviews")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  alertsOn  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id           String        @id @default(cuid())
  propertyId   String
  customerId   String
  agentId      String?
  scheduledAt  DateTime
  status       BookingStatus @default(PENDING)
  note         String?
  cancelReason String?
  reminderSentAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer User     @relation("BookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  agent    Agent?   @relation("AgentBookings", fields: [agentId], references: [id])

  @@index([propertyId])
  @@index([customerId])
  @@map("bookings")
}

// ---------------------------------------------------------------------------
// Messaging
// ---------------------------------------------------------------------------

model Conversation {
  id        String   @id @default(cuid())
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------------

model Lead {
  id            String     @id @default(cuid())
  propertyId    String?
  fullName      String
  email         String?
  phone         String?
  source        LeadSource @default(WEBSITE)
  status        LeadStatus @default(NEW)
  assigneeId    String?
  agentId       String?
  createdById   String?
  score         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property   Property? @relation(fields: [propertyId], references: [id])
  assignee   User?     @relation("LeadAssignee", fields: [assigneeId], references: [id])
  agent      Agent?    @relation("AgentLeads", fields: [agentId], references: [id])
  createdBy  User?     @relation("LeadCreatedBy", fields: [createdById], references: [id])
  notes      CrmNote[]
  tasks      CrmTask[]

  @@index([status])
  @@index([assigneeId])
  @@map("leads")
}

model CrmNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("crm_notes")
}

model CrmTask {
  id          String    @id @default(cuid())
  leadId      String
  assigneeId  String
  title       String
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  lead     Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User @relation("CrmTaskAssignee", fields: [assigneeId], references: [id])

  @@map("crm_tasks")
}

model Offer {
  id          String      @id @default(cuid())
  propertyId  String
  agentId     String?
  buyerName   String
  buyerEmail  String?
  buyerPhone  String?
  amount      Decimal     @db.Decimal(14, 2)
  currency    String      @default("USD")
  status      OfferStatus @default(PENDING)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent    Agent?   @relation("AgentOffers", fields: [agentId], references: [id])

  @@map("offers")
}

model Commission {
  id         String   @id @default(cuid())
  agentId    String
  offerId    String?
  amount     Decimal  @db.Decimal(14, 2)
  currency   String   @default("USD")
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("commissions")
}

// ---------------------------------------------------------------------------
// Rental management
// ---------------------------------------------------------------------------

model Lease {
  id            String      @id @default(cuid())
  propertyId    String
  tenantId      String
  ownerId       String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal     @db.Decimal(14, 2)
  currency      String      @default("USD")
  billingCycle  String      @default("MONTHLY")
  depositAmount Decimal?    @db.Decimal(14, 2)
  status        LeaseStatus @default(ACTIVE)
  documentUrl   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Cascade)
  owner    Owner    @relation("OwnerLeases", fields: [ownerId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  maintenanceRequests MaintenanceRequest[]

  @@index([propertyId])
  @@index([tenantId])
  @@map("leases")
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  leaseId     String
  tenantId    String
  title       String
  description String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("maintenance_requests")
}

// ---------------------------------------------------------------------------
// Payments, invoices, subscriptions
// ---------------------------------------------------------------------------

model Payment {
  id               String                 @id @default(cuid())
  userId           String
  invoiceId        String?
  provider         PaymentGatewayProvider
  providerRef      String?
  amount           Decimal                @db.Decimal(14, 2)
  currency         String                 @default("USD")
  status           PaymentStatus          @default(PENDING)
  metadata         Json?
  failureReason    String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([provider, status])
  @@map("payments")
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNumber String      @unique
  userId      String
  leaseId     String?
  status      InvoiceStatus @default(DRAFT)
  amount      Decimal       @db.Decimal(14, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(14, 2)
  currency    String        @default("USD")
  dueDate     DateTime
  paidAt      DateTime?
  lateFee     Decimal       @default(0) @db.Decimal(14, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  lease    Lease?    @relation(fields: [leaseId], references: [id])
  payments Payment[]
  lineItems InvoiceLineItem[]

  @@index([userId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(14, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Subscription {
  id           String              @id @default(cuid())
  userId       String
  plan         SubscriptionPlan    @default(FREE)
  status       SubscriptionStatus  @default(TRIALING)
  provider     PaymentGatewayProvider?
  providerRef  String?
  currentPeriodStart DateTime      @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean       @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  percentageOff  Int?
  amountOff      Decimal? @db.Decimal(14, 2)
  currency       String?  @default("USD")
  maxRedemptions Int?
  timesRedeemed  Int      @default(0)
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("coupons")
}

// ---------------------------------------------------------------------------
// Notifications & support
// ---------------------------------------------------------------------------

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  title     String
  body      String
  status    NotificationStatus  @default(PENDING)
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("notifications")
}

model SupportTicket {
  id          String                 @id @default(cuid())
  ticketNumber String                @unique
  requesterId String
  assigneeId  String?
  subject     String
  description String
  priority    SupportTicketPriority  @default(MEDIUM)
  status      SupportTicketStatus    @default(OPEN)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  resolvedAt  DateTime?

  requester User                  @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee  User?                 @relation("TicketAssignee", fields: [assigneeId], references: [id])
  replies   SupportTicketReply[]

  @@index([status])
  @@map("support_tickets")
}

model SupportTicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id])

  @@map("support_ticket_replies")
}

// ---------------------------------------------------------------------------
// Content, SEO, settings, media, audit
// ---------------------------------------------------------------------------

model BlogPost {
  id          String         @id @default(cuid())
  authorId    String
  title       String
  slug        String         @unique
  excerpt     String?
  content     String
  coverImageUrl String?
  status      BlogPostStatus @default(DRAFT)
  tags        String[]       @default([])
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author User     @relation(fields: [authorId], references: [id])
  seo    SeoMeta?

  @@map("blog_posts")
}

model SeoMeta {
  id             String    @id @default(cuid())
  propertyId     String?   @unique
  blogPostId     String?   @unique
  metaTitle      String?
  metaDescription String?
  ogImageUrl     String?
  canonicalUrl   String?
  keywords       String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  blogPost BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@map("seo_meta")
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pages")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model File {
  id           String    @id @default(cuid())
  uploaderId   String
  url          String
  publicId     String?
  provider     String    @default("CLOUDINARY")
  mimeType     String
  sizeBytes    Int
  originalName String
  createdAt    DateTime  @default(now())

  uploader User @relation(fields: [uploaderId], references: [id])

  @@map("files")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}
